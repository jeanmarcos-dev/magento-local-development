{
    "name": "jeanmarcos/module-core-local-development",
    "description": "Magento 2 shared core for local-development-only modules. Provides the production-mode guard service and the shared admin configuration tab consumed by Development_AdminBypass, Development_CustomerBypass, Development_LiveReload, and similar dev-only modules.",
    "type": "magento2-module",
    "license": "MIT",
    "keywords": [
        "magento",
        "magento2",
        "magento-2",
        "development",
        "dev-tools",
        "core",
        "production-guard"
    ],
    "authors": [
        {
            "name": "Jeanmarcos Juarez",
            "email": "janmarcoj@gmail.com"
        }
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": ">=103.0",
        "magento/module-config": "*",
        "magento/module-store": "*"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Development\\Core\\": ""
        }
    },
    "archive": {
        "exclude": [
            "/.github",
            "/tests",
            "/.gitignore",
            "/.editorconfig",
            "/phpunit.xml",
            "/phpstan.neon",
            "/phpcs.xml"
        ]
    }
}
