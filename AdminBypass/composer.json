{
    "name": "jeanmarcos/module-admin-bypass",
    "description": "Magento 2 development module that bypasses admin authentication and auto-logs in a hardcoded developer user. For local development only — guarded against production mode.",
    "type": "magento2-module",
    "license": "MIT",
    "keywords": [
        "magento",
        "magento2",
        "magento-2",
        "development",
        "dev-tools",
        "admin",
        "auth",
        "bypass",
        "autologin"
    ],
    "authors": [
        {
            "name": "Jeanmarcos Juarez",
            "email": "janmarcoj@gmail.com"
        }
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": ">=103.0",
        "magento/module-backend": "*",
        "magento/module-user": "*",
        "magento/module-authorization": "*",
        "magento/module-config": "*",
        "jeanmarcos/module-core-local-development": "^1.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Development\\AdminBypass\\": ""
        }
    },
    "archive": {
        "exclude": [
            "/.github",
            "/tests",
            "/.gitignore",
            "/.editorconfig",
            "/phpunit.xml",
            "/phpstan.neon",
            "/phpcs.xml"
        ]
    }
}
